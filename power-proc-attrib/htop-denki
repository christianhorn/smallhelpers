[denki]
heading = Denki-power
caption = Power consumption per process
default = true

power_proc_consumed.heading = W-consumed
power_proc_consumed.caption = Watt by process
power_proc_consumed.metric = openmetrics.power.proc.consumed
power_proc_consumed.width = 12

power_proc_percent.heading = %-consumed
power_proc_percent.caption = Percent of overall consumption
power_proc_percent.metric = openmetrics.power.proc.consumedpercent
# power_proc_percent.format = percent
power_proc_percent.width = 12

